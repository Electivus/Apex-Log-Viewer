{
  "name": "vscode-extension",
  "sourceRoot": "apps/vscode-extension/src",
  "projectType": "application",
  "tags": ["scope:vscode", "type:app"],
  "targets": {
    "check-types": {
      "command": "tsc --noEmit -p apps/vscode-extension/tsconfig.json"
