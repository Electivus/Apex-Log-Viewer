{
  "name": "apex-log-viewer",
  "displayName": "Electivus Apex Log Viewer",
  "description": "Fast, searchable Salesforce Apex logs in VS Code — browse, filter, tail, and debug with Apex Replay.",
  "version": "0.52.1",
  "publisher": "electivus",
  "telemetryConnectionString": "InstrumentationKey=a8895b37-e877-4b0c-bed4-0d421e313bf5;IngestionEndpoint=https://eastus-8.in.applicationinsights.azure.com/;LiveEndpoint=https://eastus.livediagnostics.monitor.azure.com/;ApplicationId=91194049-f752-4b25-934c-0cdef9251e6f",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Electivus/Apex-Log-Viewer"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "l10n": "./l10n",
  "icon": "media/icon.png",
  "galleryBanner": {
    "color": "#2563eb",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/electivus.apex-log-viewer?label=Marketplace",
      "href": "https://marketplace.visualstudio.com/items?itemName=electivus.apex-log-viewer",
      "description": "Marketplace Version"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/i/electivus.apex-log-viewer",
      "href": "https://marketplace.visualstudio.com/items?itemName=electivus.apex-log-viewer",
      "description": "Installs"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/d/electivus.apex-log-viewer",
      "href": "https://marketplace.visualstudio.com/items?itemName=electivus.apex-log-viewer",
      "description": "Downloads"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/r/electivus.apex-log-viewer",
      "href": "https://marketplace.visualstudio.com/items?itemName=electivus.apex-log-viewer",
      "description": "Rating"
    },
    {
      "url": "https://github.com/Electivus/Apex-Log-Viewer/actions/workflows/ci.yml/badge.svg?branch=main",
      "href": "https://github.com/Electivus/Apex-Log-Viewer/actions/workflows/ci.yml?query=branch%3Amain",
      "description": "CI"
    }
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:sfdx-project.json"
  ],
  "main": "./dist/extension.js",
  "files": [
    "dist/**",
    "l10n/**",
    "media/icon.png",
    "media/banner.png",
    "media/docs/**",
    "media/main.js",
    "media/webview.css",
    "media/tail.js",
    "media/logViewer.js",
    "media/debugFlags.js",
    "bin/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "telemetry.json",
    "package.json",
    "package.nls.json",
    "package.nls.pt-br.json"
  ],
  "contributes": {
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "electivus.apexLogViewer.logs.pageSize": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "markdownDescription": "%configuration.electivus.apexLogViewer.logs.pageSize.description%"
        },
        "electivus.apexLogViewer.logs.processingConcurrency": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "markdownDescription": "%configuration.electivus.apexLogViewer.logs.processingConcurrency.description%"
        },
        "electivus.apexLogViewer.tail.bufferLines": {
          "type": "number",
          "default": 10000,
          "minimum": 1000,
          "maximum": 200000,
          "markdownDescription": "%configuration.electivus.apexLogViewer.tail.bufferLines.description%"
        },
        "electivus.apexLogViewer.logging.trace": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%configuration.electivus.apexLogViewer.logging.trace.description%"
        },
        "electivus.apexLogViewer.logs.columns": {
          "type": "object",
          "default": {
            "order": [
              "user",
              "application",
              "operation",
              "time",
              "duration",
              "status",
              "size",
              "match"
            ],
            "visibility": {
              "user": true,
              "application": true,
              "operation": true,
              "time": true,
              "duration": true,
              "status": true,
              "size": true,
              "match": true
            },
            "widths": {}
          },
          "markdownDescription": "%configuration.electivus.apexLogViewer.logs.columns.description%",
          "properties": {
            "order": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": [
                  "user",
                  "application",
                  "operation",
                  "time",
                  "duration",
                  "status",
                  "size",
                  "match"
                ]
              }
            },
            "visibility": {
              "type": "object",
              "properties": {
                "user": {
                  "type": "boolean"
                },
                "application": {
                  "type": "boolean"
                },
                "operation": {
                  "type": "boolean"
                },
                "time": {
                  "type": "boolean"
                },
                "duration": {
                  "type": "boolean"
                },
                "status": {
                  "type": "boolean"
                },
                "size": {
                  "type": "boolean"
                },
                "match": {
                  "type": "boolean"
                }
              }
            },
            "widths": {
              "type": "object",
              "properties": {
                "user": {
                  "type": "number",
                  "minimum": 1
                },
                "application": {
                  "type": "number",
                  "minimum": 1
                },
                "operation": {
                  "type": "number",
                  "minimum": 1
                },
                "time": {
                  "type": "number",
                  "minimum": 1
                },
                "duration": {
                  "type": "number",
                  "minimum": 1
                },
                "status": {
                  "type": "number",
                  "minimum": 1
                },
                "size": {
                  "type": "number",
                  "minimum": 1
                },
                "match": {
                  "type": "number",
                  "minimum": 1
                }
              }
            }
          }
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "electivus-apex-log-viewer-logs",
          "title": "%salesforce.panel.title%",
          "icon": "media/icon.png"
        },
        {
          "id": "electivus-apex-log-viewer-tail",
          "title": "%salesforce.tail.panel.title%",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "electivus-apex-log-viewer-logs": [
        {
          "id": "electivus.apexLogViewer.logsView",
          "name": "%salesforce.logs.view.name%",
          "type": "webview"
        }
      ],
      "electivus-apex-log-viewer-tail": [
        {
          "id": "electivus.apexLogViewer.tailView",
          "name": "%salesforce.tail.view.name%",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "electivus.apexLogViewer.logs.refresh",
        "title": "%command.refresh.title%",
        "category": "Electivus Apex Logs"
      },
      {
        "command": "electivus.apexLogViewer.org.select",
        "title": "%command.selectOrg.title%",
        "category": "Electivus Apex Logs"
      },
      {
        "command": "electivus.apexLogViewer.tail.start",
        "title": "%command.tail.title%",
        "category": "Electivus Apex Logs"
      },
      {
        "command": "electivus.apexLogViewer.logs.openEditor",
        "title": "%command.openLogsEditor.title%",
        "category": "Electivus Apex Logs"
      },
      {
        "command": "electivus.apexLogViewer.tail.openEditor",
        "title": "%command.openTailEditor.title%",
        "category": "Electivus Apex Logs"
      },
      {
        "command": "electivus.apexLogViewer.log.openViewer",
        "title": "%command.openLogInViewer.title%",
        "category": "Electivus Apex Logs"
      },
      {
        "command": "electivus.apexLogViewer.output.show",
        "title": "Show Extension Output",
        "category": "Electivus Apex Logs"
      },
      {
        "command": "electivus.apexLogViewer.diagnostics.copy",
        "title": "%command.copyDiagnostics.title%",
        "category": "Electivus Apex Logs"
      }
    ],
    "languages": [
      {
        "id": "apexlog",
        "aliases": [
          "ApexLog",
          "Salesforce Apex Log"
        ],
        "firstLine": "^\\d{2}\\.\\d{2}.+?APEX_CODE,\\w.+$"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "electivus.apexLogViewer.logs.openEditor",
          "when": "view == electivus.apexLogViewer.logsView",
          "group": "navigation@10",
          "icon": "$(open-preview)"
        },
        {
          "command": "electivus.apexLogViewer.tail.openEditor",
          "when": "view == electivus.apexLogViewer.tailView",
          "group": "navigation@10",
          "icon": "$(open-preview)"
        },
        {
          "command": "electivus.apexLogViewer.diagnostics.copy",
          "when": "view == electivus.apexLogViewer.logsView || view == electivus.apexLogViewer.tailView",
          "group": "moreActions@99"
        },
        {
          "command": "electivus.apexLogViewer.output.show",
          "when": "view == electivus.apexLogViewer.logsView || view == electivus.apexLogViewer.tailView",
          "group": "moreActions@100"
        }
      ],
      "editor/title": [
        {
          "command": "electivus.apexLogViewer.log.openViewer",
          "when": "resourceLangId == apexlog",
          "group": "navigation@50",
          "icon": "$(open-preview)"
        }
      ]
    }
  },
  "dependencies": {
    "@alv/core": "workspace:*",
    "@alv/protocol": "workspace:*",
    "@jsforce/jsforce-node": "3.10.19",
    "@vscode/extension-telemetry": "^1.5.2",
    "cross-spawn": "^7.0.6",
    "yaml": "^2.9.0"
  },
  "homepage": "https://github.com/Electivus/Apex-Log-Viewer#readme",
  "bugs": {
    "url": "https://github.com/Electivus/Apex-Log-Viewer/issues"
  },
  "keywords": [
    "salesforce",
    "apex",
    "logs",
    "developer",
    "tooling",
    "tail",
    "debug"
  ]
}
