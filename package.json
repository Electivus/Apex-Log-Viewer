{
  "name": "apex-log-viewer",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test:clean": "node scripts/clean-vscode-test.js",
    "test:clean:all": "node scripts/clean-vscode-test.js --force",
    "clean": "node -e \"const fs=require('fs');const del=d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}};del('dist');del('out');del('apps/vscode-extension/bin');del('apps/vscode-extension/node_modules/tree-sitter-sfapex');for(const f of ['apps/vscode-extension/README.md','apps/vscode-extension/CHANGELOG.md','apps/vscode-extension/LICENSE','apps/vscode-extension/telemetry.json','apps/vscode-extension/media/main.js','apps/vscode-extension/media/main.js.map','apps/vscode-extension/media/tail.js','apps/vscode-extension/media/tail.js.map','apps/vscode-extension/media/logViewer.js','apps/vscode-extension/media/logViewer.js.map','apps/vscode-extension/media/debugFlags.js','apps/vscode-extension/media/debugFlags.js.map','apps/vscode-extension/media/webview.css']){try{fs.unlinkSync(f)}catch{}}\"",
    "prebuild": "npm run clean",
    "vscode:prepublish": "npm run build && npm run nls:write",
    "check-types": "tsc --noEmit -p tsconfig.extension.json",
    "compile": "npm run lint && tsc -p tsconfig.extension.json --noEmit",
    "watch": "npm-run-all -s build:runtime build:tree-sitter-runtime build:package-metadata -p watch:*",
    "watch:extension": "node apps/vscode-extension/esbuild.extension.mjs --watch",
    "watch:tsc": "tsc -p tsconfig.extension.json --watch --noEmit",
    "watch:webview": "npm-run-all -p tailwind:watch watch:webview:bundle",
    "build:runtime": "cargo build -p apex-log-viewer-cli --bin apex-log-viewer && node apps/vscode-extension/scripts/copy-runtime-binary.mjs",
    "package:runtime": "node scripts/fetch-runtime-release.mjs",
    "package:runtime:local": "node scripts/build-runtime-target.mjs release",
    "build:cli:npm": "node scripts/build-cli-npm-packages.mjs",
    "build:tree-sitter-runtime": "node apps/vscode-extension/scripts/copy-tree-sitter-runtime.mjs",
    "build:package-metadata": "node apps/vscode-extension/scripts/copy-package-metadata.mjs",
    "build:extension": "npm run build:runtime && npm run build:tree-sitter-runtime && npm run build:package-metadata && node apps/vscode-extension/esbuild.extension.mjs --minify",
    "build:webview": "npm-run-all -s tailwind:build build:webview:bundle",
    "build": "npm run build:extension && npm run build:webview",
    "build:icon": "node scripts/gen-icon.mjs",
    "build:assets": "node scripts/gen-assets.mjs",
    "nls:extract": "vscl \"apps/vscode-extension/dist/**/*.js\"",
    "nls:write": "node scripts/gen-nls.cjs",
    "prepackage": "npm run clean",
    "package": "npm run package:runtime && npm run build:tree-sitter-runtime && npm run build:package-metadata && node apps/vscode-extension/esbuild.extension.mjs && (npm run -s nls:extract || true) && npm run nls:write && npm run build:webview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"apps/vscode-extension/src/**/*.{ts,tsx}\" \"packages/app-server-client-ts/src/**/*.{ts,tsx}\" \"packages/webview/src/**/*.{ts,tsx}\"",
    "vsce:package": "node scripts/run-vsce.js package --no-yarn",
    "vsce:package:pre": "node scripts/run-vsce.js package --no-yarn --pre-release",
    "vsce:publish": "node scripts/run-vsce.js publish",
    "vsce:publish:pre": "node scripts/run-vsce.js publish --pre-release",
    "compile-tests": "node -e \"try{require('fs').rmSync('out/test',{recursive:true,force:true})}catch(e){}\" && tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p tsconfig.test.watch.json -w",
    "pretest": "npm run test:linux-deps && npm run build:extension && npm run compile-tests",
    "test:scripts": "node --test scripts/run-node-tests.test.js scripts/run-tests-cli.test.js scripts/run-tests.test.js scripts/run-rust-tests.test.js scripts/run-vsce.test.js scripts/copy-runtime-binary.test.js scripts/copy-tree-sitter-runtime.test.js scripts/copy-package-metadata.test.js scripts/build-cli-npm-packages.test.js scripts/fetch-runtime-release.test.js scripts/compute-prerelease-version.test.js scripts/publish-npm-package-if-needed.test.js scripts/verify-runtime-compatibility.test.js scripts/packaging-ci.test.js scripts/repo-security.test.js scripts/check-dependency-sources.test.js scripts/docs-release.test.js scripts/deploy-azure-monitor.test.js scripts/azure-monitor-helpers.test.js scripts/eslint-type-aware.test.js scripts/run-playwright-e2e.test.js scripts/run-playwright-cli-e2e.test.js scripts/run-e2e-proxy-lab.test.js scripts/cli-e2e-workflow.test.js scripts/run-playwright-e2e-telemetry.test.js scripts/resolve-vscode-cache-metadata.test.js scripts/scratch-pool-admin.test.js && node scripts/check-dependency-sources.mjs",
    "security:dependency-sources": "node scripts/check-dependency-sources.mjs",
    "security:npm-signatures": "npm audit signatures",
    "test:rust": "node scripts/run-rust-tests.js --workspace",
    "test:rust:smoke": "node scripts/run-rust-tests.js --smoke",
    "test:rust:nextest": "node scripts/run-rust-tests.js --workspace --nextest",
    "test:rust:smoke:nextest": "node scripts/run-rust-tests.js --smoke --nextest",
    "test": "npm run test:webview && npm run test:extension:node && npm run test:scripts && node scripts/run-tests-cli.js --scope=unit --coverage && npm run coverage:merge",
    "test:unit": "npm run test:webview && npm run test:e2e:utils && npm run test:extension:node && npm run test:scripts && npm run pretest && node scripts/run-tests-cli.js --scope=unit",
    "test:integration": "npm run test:scripts && npm run pretest && node scripts/run-tests-cli.js --scope=integration --install-deps --timeout=900000",
    "test:all": "npm run test:webview && npm run test:extension:node && npm run test:scripts && npm run pretest && node scripts/run-tests-cli.js --scope=all",
    "test:linux-deps": "bash scripts/install-linux-deps.sh",
    "test:unit:ci": "npm run test:webview -- --ci --runInBand && npm run test:e2e:utils && npm run test:extension:node && npm run test:scripts && npm run pretest && node scripts/run-tests-cli.js --scope=unit --vscode=stable",
    "test:extension:node": "node scripts/run-node-tests.js",
    "test:integration:ci": "npm run test:scripts && npm run pretest && node scripts/run-tests-cli.js --scope=integration --vscode=stable --install-deps --timeout=900000",
    "test:webview": "jest --config jest.config.webview.cjs",
    "test:e2e:utils": "jest --config jest.config.e2e-utils.cjs --runInBand",
    "test:webview:watch": "npm run test:webview -- --watch",
    "test:ci": "npm run test:rust && npm run test:unit:ci && npm run test:integration:ci",
    "test:smoke:vsix": "node scripts/run-tests.js --scope=unit --smoke-vsix",
    "pretest:e2e": "npm run build",
    "test:e2e": "node scripts/run-playwright-e2e.js",
    "test:e2e:cli": "node scripts/run-playwright-cli-e2e.js",
    "test:e2e:proxy-lab": "node scripts/run-e2e-proxy-lab.js",
    "predocs:screenshots": "npm run build",
    "docs:screenshots": "node scripts/run-playwright-e2e.js --config=playwright.docs.config.ts",
    "pretest:e2e:telemetry": "npm run build",
    "test:e2e:telemetry": "node scripts/run-playwright-e2e-telemetry.js",
    "scratch-pool:bootstrap": "node scripts/scratch-pool-admin.js bootstrap",
    "scratch-pool:list": "node scripts/scratch-pool-admin.js list",
    "scratch-pool:reconcile": "node scripts/scratch-pool-admin.js reconcile",
    "scratch-pool:prewarm": "node scripts/scratch-pool-admin.js prewarm",
    "scratch-pool:disable-slot": "node scripts/scratch-pool-admin.js disable-slot",
    "scratch-pool:reset-slot": "node scripts/scratch-pool-admin.js reset-slot",
    "telemetry:report": "node scripts/report-telemetry-usage.js",
    "format": "prettier --write .",
    "prepare": "husky",
    "tailwind:build": "tailwindcss -c tailwind.config.js -i ./packages/webview/src/styles/tailwind.css -o ./apps/vscode-extension/media/webview.css --minify",
    "tailwind:watch": "tailwindcss -c tailwind.config.js -i ./packages/webview/src/styles/tailwind.css -o ./apps/vscode-extension/media/webview.css --watch",
    "build:webview:bundle": "node packages/webview/esbuild.webview.mjs --minify",
    "watch:webview:bundle": "node packages/webview/esbuild.webview.mjs --watch",
    "coverage:merge": "node scripts/merge-coverage.cjs",
    "azure:monitor:deploy": "node scripts/deploy-azure-monitor.js",
    "azure:monitor:what-if": "node scripts/deploy-azure-monitor.js --what-if"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "~25.5.0",
    "@types/proxyquire": "^1.3.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.56.1",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "autoprefixer": "^10.4.27",
    "c8": "^11.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.5",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "proxyquire": "^2.1.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-window": "^2.2.7",
    "sharp": "^0.34.5",
    "shell-quote": "^1.8.3",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "undici": "^7.24.5",
    "vscode-nls-dev": "^4.0.4",
    "yaml": "^2.8.3",
    "nx": "^22.0.0",
    "@nx/js": "^22.0.0",
    "@nx/workspace": "^22.0.0"
  },
  "dependencies": {
    "@jsforce/jsforce-node": "^3.10.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@vscode/extension-telemetry": "^1.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-spawn": "^7.0.6",
    "lucide-react": "^1.8.0",
    "tailwind-merge": "^3.5.0",
    "tree-sitter-sfapex": "git+https://github.com/manoelcalixto/tree-sitter-sfapex.git#685c57c5461eb247d019b244f2130e198c7cc706",
    "vscode-nls": "^5.2.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.3"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,json,md,css,scss}": "prettier --write",
    "*.log": "node scripts/guard-forbidden-staged.cjs --label=.log",
    "*.txt": "node scripts/guard-forbidden-staged.cjs --label=.txt"
  }
}
