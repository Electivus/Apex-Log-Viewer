{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "type": "npm",
      "script": "watch",
      "isBackground": true,
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": [
        "$tsc-watch",
        {
          "owner": "esbuild",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": { "regexp": "^✘ \\u005bERROR\\u005d (.*)$", "message": 1 },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^\\[watch\\] build started$",
            "endsPattern": "^\\[watch\\] build finished(?:, watching for changes\\.\\.\\.)?$"
          }
        }
      ]
    },
    {
      "label": "watch:extension",
      "type": "npm",
      "script": "watch:extension",
      "isBackground": true,
      "group": "build",
      "problemMatcher": [
        {
          "owner": "esbuild",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": { "regexp": "^✘ \\u005bERROR\\u005d (.*)$", "message": 1 },
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^\\[watch\\] build started$",
            "endsPattern": "^\\[watch\\] build finished(?:, watching for changes\\.\\.\\.)?$"
          }
        }
      ]
    },
    {
      "label": "watch:webview",
      "type": "npm",
      "script": "watch:webview",
      "isBackground": true,
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "watch-tests",
      "type": "npm",
      "script": "watch-tests",
      "isBackground": true,
      "group": "test",
      "problemMatcher": ["$tsc-watch"]
    },
    {
      "label": "compile",
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "build:extension",
      "type": "npm",
      "script": "build:extension",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "build:webview",
      "type": "npm",
      "script": "build:webview",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "package",
      "type": "npm",
      "script": "package",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "test:unit",
      "type": "npm",
      "script": "test:unit",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "test:integration",
      "type": "npm",
      "script": "test:integration",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "test:smoke:vsix",
      "type": "npm",
      "script": "test:smoke:vsix",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "cargo: fmt --all",
      "type": "process",
      "command": "cargo",
      "args": ["fmt", "--all"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "cargo: clippy --workspace",
      "type": "process",
      "command": "cargo",
      "args": ["clippy", "--workspace", "--all-targets", "--", "-D", "warnings"],
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo: test alv-core",
      "type": "process",
      "command": "cargo",
      "args": ["test", "-p", "alv-core"],
      "group": "test",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo: test alv-app-server",
      "type": "process",
      "command": "cargo",
      "args": ["test", "-p", "alv-app-server"],
      "group": "test",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo: test alv-cli",
      "type": "process",
      "command": "cargo",
      "args": ["test", "-p", "alv-cli"],
      "group": "test",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo: test runtime",
      "dependsOrder": "sequence",
      "dependsOn": [
        "cargo: test alv-core",
        "cargo: test alv-app-server",
        "cargo: test alv-cli"
      ],
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "cargo: build alv-cli",
      "type": "process",
      "command": "cargo",
      "args": ["build", "-p", "alv-cli"],
      "group": "build",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo: run alv-cli",
      "type": "process",
      "command": "cargo",
      "args": ["run", "-p", "alv-cli", "--"],
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "cargo: run app-server --stdio",
      "type": "process",
      "command": "cargo",
      "args": ["run", "-p", "alv-cli", "--", "app-server", "--stdio"],
      "problemMatcher": ["$rustc"]
    }
  ]
}
