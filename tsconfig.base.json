{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "noEmit": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "baseUrl": ".",
    "paths": {
      "@alv/webview/*": [
        "packages/webview/src/*"
      ],
      "@alv/app-server-client-ts/*": [
        "packages/app-server-client-ts/src/*"
      ],
      "@alv/vscode-extension/*": [
        "apps/vscode-extension/src/*"
      ]
    }
  }
}
