{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "apps/vscode-extension/out",
    "noEmit": true,
    "sourceMap": true,
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "react-window": [
        "apps/vscode-extension/src/test/stubs/react-window"
      ]
    }
  },
  "include": [
    "apps/vscode-extension/src/**/*.ts",
    "packages/webview/src/i18n.ts",
    "packages/webview/src/utils/logViewerParser.ts",
    "packages/webview/src/utils/tail.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "media",
    "out",
    "apps/vscode-extension/out",
    "Visual Prototype for Apex Log",
    "Visual Prototype for Apex Log/**/*"
  ]
}
