{
  "extends": "./tsconfig.test.json",
  "compilerOptions": {
    "types": ["jest", "node", "@testing-library/jest-dom"],
    "isolatedModules": true,
    "module": "CommonJS",
    "moduleResolution": "Node"
  },
  "include": [
    "packages/webview/src/**/*.ts",
    "packages/webview/src/**/*.tsx",
    "apps/vscode-extension/src/shared/**/*.ts",
    "apps/vscode-extension/src/shared/**/*.tsx"
  ],
  "exclude": [
    "packages/webview/src/__tests__/styleMock.js"
  ]
}
