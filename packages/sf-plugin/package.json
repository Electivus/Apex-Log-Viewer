{
  "name": "@electivus/plugin-electivus",
  "version": "0.1.18",
  "private": true,
  "description": "Salesforce CLI plugin for Electivus Apex Log Viewer workflows.",
  "type": "module",
  "license": "MIT",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "/bin",
    "/lib",
    "/messages",
    "/skills",
    "/oclif.manifest.json"
  ],
  "scripts": {
    "build": "node ../../scripts/copy-sf-plugin-skill.mjs && tsc -p tsconfig.json && oclif manifest",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "clean": "node -e \"const fs=require('fs');const del=d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch{}};del('lib');del('skills');for(const f of ['oclif.manifest.json','oclif.lock']){try{fs.unlinkSync(f)}catch{}}\"",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@jsforce/jsforce-node": "3.9.0",
    "@oclif/core": "^4.8.0",
    "@salesforce/core": "^7.5.0",
    "@salesforce/sf-plugins-core": "^10.0.1"
  },
  "devDependencies": {
    "oclif": "^4.23.27",
    "tsx": "^4.22.4"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "keywords": [
    "salesforce",
    "sf",
    "sf-plugin",
    "apex",
    "logs",
    "electivus"
  ],
  "oclif": {
    "commands": "./lib/commands",
    "bin": "sf",
    "topicSeparator": " ",
    "topics": {
      "electivus": {
        "description": "Electivus Salesforce tools."
      }
    },
    "flexibleTaxonomy": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Electivus/Apex-Log-Viewer"
  }
}
