FROM node:24.15.0-bookworm@sha256:f22d6a1f082c02f292e86929b5b0442ac2e5eaf438a5dea9b1566601c3e05940

ARG ALV_E2E_PROXY_LAB_APT_TIMEOUT_SECONDS=20
ARG ALV_E2E_PROXY_LAB_APT_RETRIES=3

ENV DEBIAN_FRONTEND=noninteractive

RUN { \
    echo "Acquire::Retries \"${ALV_E2E_PROXY_LAB_APT_RETRIES}\";"; \
    echo "Acquire::http::Timeout \"${ALV_E2E_PROXY_LAB_APT_TIMEOUT_SECONDS}\";"; \
    echo "Acquire::https::Timeout \"${ALV_E2E_PROXY_LAB_APT_TIMEOUT_SECONDS}\";"; \
  } > /etc/apt/apt.conf.d/99alv-proxy-lab-timeouts \
  && apt-get update \
  && apt-get install -y --no-install-recommends \
    bash \
    build-essential \
    ca-certificates \
    curl \
    git \
    jq \
    libasound2 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnss3 \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libx11-xcb1 \
    libxcb-dri2-0 \
    libxcb-dri3-0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libxshmfence1 \
    libxss1 \
    libxtst6 \
    openssh-client \
    python3 \
    sudo \
    xauth \
    xvfb \
  && rm -rf /var/lib/apt/lists/*

RUN npm install -g @salesforce/cli@2.136.8 --no-audit --no-fund

WORKDIR /workspace
